#!/usr/bin/env bash

set -o nounset -o pipefail

if [[ ${TRACE:-0} == "1" ]]; then
  set -o xtrace
fi

run_command() {
  if ! "${@}"; then
    var_error "Commit Failed!"
    var_error "Please fix errors and try committing again."

    exit 1
  fi
}

get_files() {
  git diff --name-only --diff-filter=ACMR --cached -- "${@}" | tr '\n' ' ' | sed "s| *$||g"
}

get_diff() {
  git diff --name-only --diff-filter=ACMR
}

diff_check() {
  if [[ ${1} != $(get_diff) ]]; then
    var_error "Pre-commit has changed files"
    printf -- "%bConsider adding updated file with %bgit add --interactive && git commit --amend%b\n" "${RED}" "${BLUE}" "${RESET}" 1>&2
  fi
}

golang_check() {
  local GO_FILES
  GO_FILES=$(get_files "*.go")

  if [[ -z ${GO_FILES-} ]]; then
    return
  fi

  if command -v goimports >/dev/null 2>&1 && command -v gofumpt >/dev/null 2>&1; then
    for file in ${GO_FILES}; do
      if [[ $(head -1 "${file}") =~ '// Code generated by' ]]; then
        continue
      fi

      goimports -w "${file}"
      gofumpt -w "${file}"
    done
  else
    var_warning "cannot format Golang files: goimports or gofumpt not found. Skipping."
  fi

  if ! [[ -e "Makefile" ]]; then
    return
  fi

  local MAKE_TARGETS
  MAKE_TARGETS="$(make -pqr 2>/dev/null | awk -F':' '/^[a-zA-Z0-9][^$#\/\t=]*:([^=]|$)/ {split($1,A,/ /);for(i in A)print A[i]}' | grep --invert-match "Makefile" | sort --unique)"

  if [[ $(printf -- "%s" "${MAKE_TARGETS}" | grep --count "style") -eq 1 ]]; then
    var_info "Linting Golang packages..."
    run_command make --silent style
  elif [[ $(printf -- "%s" "${MAKE_TARGETS}" | grep --count "lint") -eq 1 ]]; then
    var_info "Linting Golang packages..."
    run_command make --silent lint
  fi
}

bazel_check() {
  if [[ $(git config "hooks.bazelleGazelle") != "true" ]]; then
    return
  fi

  if ! command -v bzl >/dev/null 2>&1; then
    return
  fi

  local CHANGED_FILES
  CHANGED_FILES=$(get_files "*")

  if [[ -z ${CHANGED_FILES-} ]]; then
    return
  fi

  local DIRNAMES=()

  for file in ${CHANGED_FILES}; do
    local CHANGED_DIRNAME
    CHANGED_DIRNAME="$(dirname "${file}")"

    if [[ -e "${CHANGED_DIRNAME}/BUILD.bazel" ]]; then
      DIRNAMES+=("${CHANGED_DIRNAME}")
    fi
  done

  if [[ ${#DIRNAMES[@]} -eq 0 ]]; then
    return
  fi

  local COMMON_PREFIX
  COMMON_PREFIX="${DIRNAMES[0]}"

  for ((i = 1; i < ${#DIRNAMES[@]}; i++)); do
    while [[ ${DIRNAMES[i]} != "${COMMON_PREFIX}"* ]]; do
      COMMON_PREFIX=$(dirname "${COMMON_PREFIX}")
      if [[ ${COMMON_PREFIX} == "/" ]] || [[ ${COMMON_PREFIX} == "." ]]; then
        break
      fi
    done
  done

  if [[ ${COMMON_PREFIX} != "/" ]] && [[ ${COMMON_PREFIX} != "." ]]; then
    var_info "Checking Bazel Gazelle for ${COMMON_PREFIX}/"
    run_command bzl run --ui_event_filters=-INFO,-DEBUG,-STDOUT,-STDERR --show_progress=false --color=no //:gazelle -- fix "${COMMON_PREFIX}/"
  fi
}

npm_check() {
  if ! [[ -e "package.json" ]]; then
    return
  fi

  local PACKAGE_JSON
  PACKAGE_JSON=$(get_files "package.json")

  local JS_FILES
  JS_FILES=$(get_files \*.js{,x})

  if [[ -z ${PACKAGE_JSON-} ]] && [[ -z ${JS_FILES-} ]]; then
    return
  fi

  if command -v npm >/dev/null 2>&1; then
    var_info "Checking node_modules installation"
    run_command npm --silent install --no-audit --ignore-scripts
  else
    var_warning "cannot check node_modules lock file: npm not found. Skipping."
  fi

  if [[ -n ${JS_FILES:-} ]]; then
    if command -v npm >/dev/null 2>&1; then
      var_info "Formatting javascript files"
      run_command npm --silent run --if-present format ${JS_FILES[@]}

      var_info "Linting javascript files"
      run_command npm --silent run --if-present style ${JS_FILES[@]}
    else
      var_warning "cannot format and lint javascript files: npm not found. Skipping."
    fi
  fi
}

python_check() {
  local PYTHON_FILES
  PYTHON_FILES=$(get_files \*.py)

  if [[ -z ${PYTHON_FILES-} ]]; then
    return
  fi

  if command -v isort >/dev/null 2>&1 && command -v black >/dev/null 2>&1; then
    var_info "Formatting Python files"
    run_command isort --quiet ${PYTHON_FILES[@]}
    run_command black --quiet ${PYTHON_FILES[@]}
  else
    var_warning "cannot format Python files: isort or black not found. Skipping."
  fi
}

terraform_check() {
  local TERRAFORM_FILES
  TERRAFORM_FILES=$(get_files "*.tf")

  if [[ -z ${TERRAFORM_FILES} ]]; then
    return
  fi

  if command -v terraform >/dev/null 2>&1; then
    var_info "Formatting Terraform files..."

    for file in ${TERRAFORM_FILES}; do
      run_command terraform fmt "$(dirname "${file}")"
    done
  else
    var_warning "cannot format Terraform files: terraform not found. Skipping."
  fi
}

yaml_check() {
  local YAML_FILES
  YAML_FILES=$(get_files \*.y{,a}ml ':(exclude)*/fixtures/*')

  if [[ -z ${YAML_FILES} ]]; then
    return
  fi

  if [[ $(git config "hooks.noYamlFormat") != "true" ]]; then
    if command -v npx >/dev/null 2>&1; then
      var_info "Formatting YAML files..."

      run_command npx prettier --write ${YAML_FILES[@]}
    else
      var_warning "cannot format YAML files: npx not found. Skipping."
    fi
  else
    var_green 'No formatting of YAML files. Toggle with `git_hooks_no_yaml_format`'
  fi

  if command -v yamllint >/dev/null 2>&1; then
    var_info "Linting YAML files"

    run_command yamllint -d "{rules: {line-length: disable}}" ${YAML_FILES[@]}
  else
    var_warning "cannot lint YAML files: yamllint not found. Skipping."
  fi
}

json_check() {
  if [[ $(git config "hooks.jsonSort") != "true" ]]; then
    return
  fi

  local JSON_FILES
  JSON_FILES=$(get_files "*.json")

  if [[ -z ${JSON_FILES} ]]; then
    return
  fi

  if command -v jq >/dev/null 2>&1; then
    var_info "Sorting JSON files..."

    for file in ${JSON_FILES}; do
      local TEMP_FILE
      TEMP_FILE=$(mktemp)

      var_info "\tProcessing ${file}"

      run_command jq --sort-keys . "${file}" >"${TEMP_FILE}"
      mv -- "${TEMP_FILE}" "${file}"
    done
  else
    var_warning "cannot format json files: jq not found. Skipping."
  fi
}

markdown_check() {
  local MARKDOWN_FILES
  MARKDOWN_FILES=$(get_files "*.md")

  if [[ -z ${MARKDOWN_FILES} ]]; then
    return
  fi

  if [[ $(git config "hooks.noMarkdownFormat") != "true" ]]; then
    if command -v npx >/dev/null 2>&1; then
      var_info "Formatting Markdown files..."
      run_command npx prettier --write ${MARKDOWN_FILES[@]}
    else
      var_warning "cannot format Markdown files: npx not found. Skipping."
    fi
  else
    var_green 'No formatting of Markdown files. Toggle with `git_hooks_no_md_format`'
  fi
}

script_dir() {
  local FILE_SOURCE="${BASH_SOURCE[0]}"

  if [[ -L ${FILE_SOURCE} ]]; then
    dirname "$(readlink "${FILE_SOURCE}")"
  else
    (
      cd "$(dirname "${FILE_SOURCE}")" && pwd
    )
  fi
}

main() {
  if [[ ${SCRIPTS_NO_GIT_HOOKS:-} == "true" ]]; then
    return 0
  fi

  source "$(script_dir)/../scripts/meta" && meta_check "var"

  local INITIAL_DIFF
  INITIAL_DIFF=$(get_diff)

  golang_check
  bazel_check
  npm_check
  python_check
  terraform_check
  json_check
  yaml_check
  markdown_check

  diff_check "${INITIAL_DIFF}"

  exit 0
}

main
