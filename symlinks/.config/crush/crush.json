{
  "$schema": "https://charm.land/crush.json",
  "providers": {
    "anthropic": {
      "api_key": "$(pass datadog/anthropic)"
    }
  },
  "models": {
    "large": {
      "model": "claude-sonnet-4-6",
      "provider": "anthropic",
      "reasoning_effort": "high",
      "max_tokens": 64000
    }
  },
  "lsp": {
    "go": {
      "command": "gopls",
      "filetypes": [
        "go"
      ]
    },
    "python": {
      "command": "pylsp",
      "filetypes": [
        "python"
      ]
    },
    "typescript": {
      "command": "typescript-language-server",
      "args": [
        "--stdio"
      ],
      "filetypes": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
      ],
      "init_options": {
        "maxTsServerMemory": 16384,
        "tsserver": {
          "path": "$HOME/opt/node/lib/node_modules/typescript/lib/"
        }
      }
    },
    "terraform": {
      "command": "terraform-ls",
      "args": [
        "serve"
      ],
      "filetypes": [
        "terraform"
      ]
    }
  },
  "options": {
    "disable_metrics": true,
    "context_paths": [
      "$HOME/.config/crush/AGENTS.md"
    ]
  },
  "permissions": {
    "allowed_tools": [
      "mcp__atlassian__getConfluencePage",
      "mcp__atlassian__getConfluencePageDescendants",
      "mcp__atlassian__getJiraIssue",
      "mcp__atlassian__searchConfluenceUsingCql",
      "mcp__atlassian__searchJiraIssuesUsingJql",
      "mcp__datadog-google-workspace__get_presentation",
      "mcp__datadog-google-workspace__get_slide",
      "mcp__datadog-google-workspace__get_slide_thumbnail",
      "mcp__datadog__aggregate_spans",
      "mcp__datadog__get_datadog_notebook",
      "mcp__datadog__get_datadog_trace",
      "mcp__datadog__list_datadog_skills",
      "mcp__datadog__load_datadog_skill",
      "mcp__datadog__search_datadog_spans"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^bash$",
        "command": "${HOME}/.config/crush/hooks/bash-policy.sh"
      }
    ]
  }
}
